# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and update with your actual values
# ============================================================================

# FLASK CONFIGURATION
# Change this to a secure random string in production
SECRET_KEY=your-super-secret-key-change-in-production-12345

# MONGODB ATLAS CONNECTION
# Get from MongoDB Atlas cluster connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
# IMPORTANT: Ensure TLS is enabled (tls=true in URI)
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/legal_service?retryWrites=true&w=majority&tls=true

# ENCRYPTION KEY
# Must be 32 bytes for AES-256
# Generate with: python -c "import os; print(os.urandom(32))"
# Or use: openssl rand -hex 32
ENCRYPTION_KEY=b'this-is-a-32-byte-encryption-key-change-this'

# OTP ENCRYPTION KEY
# Optional: if not set, ENCRYPTION_KEY is reused.
OTP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# RSA & SIGNATURE KEYS
# File paths used for RSA hybrid encryption and per-user signature keys.
RSA_PRIVATE_KEY_PATH=keys/rsa_private.pem
RSA_PUBLIC_KEY_PATH=keys/rsa_public.pem
SIGNATURE_KEYS_DIR=keys/signatures

# DIFFIE-HELLMAN DEMO
ENABLE_DH_DEMO=true

# HTTPS SELF-SIGNED CERTIFICATE SUPPORT
# Generate with:
# openssl req -x509 -newkey rsa:2048 -keyout certs/key.pem -out certs/cert.pem -days 365 -nodes
ENABLE_HTTPS=false
SSL_CERT_FILE=certs/cert.pem
SSL_KEY_FILE=certs/key.pem

# GMAIL SMTP CONFIGURATION (FOR OTP)
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to Account → Security → App Passwords
# 3. Select "Mail" and "Windows (or custom)"
# 4. Google will generate a 16-character password
# 5. Use that password below (not your regular account password)

MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=your-16-character-app-password

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================

# 1. MONGODB ATLAS SETUP
#    a. Go to https://www.mongodb.com/cloud/atlas
#    b. Sign up for free account
#    c. Create M0 (free) cluster
#    d. Add database user (username/password)
#    e. Click "Connect" and copy connection string
#    f. Update MONGO_URI above with your credentials

# 2. GMAIL APP PASSWORD
#    a. Go to https://myaccount.google.com/
#    b. Security → 2-Step Verification (enable if needed)
#    c. Security → App Passwords
#    d. Select "Mail" and "Windows (or custom)"
#    e. Copy generated password
#    f. Update MAIL_USERNAME and MAIL_PASSWORD

# 3. ENCRYPTION KEY
#    IMPORTANT: This key must be exactly 32 bytes for AES-256
#    Generate secure key:
#    
#    Python method:
#    >>> import os
#    >>> key = os.urandom(32)
#    >>> print(key)
#    b'...'  # Copy this value
#
#    Or use OpenSSL:
#    $ openssl rand -hex 32

# ============================================================================
# SECURITY NOTES
# ============================================================================

# - NEVER commit .env file to version control
# - NEVER hardcode credentials in source code
# - Use strong random values (not example values)
# - Rotate encryption keys periodically
# - Keep MongoDB credentials secure
# - Use production IP whitelisting in MongoDB Atlas
# - Enable database encryption at rest
# - Maintain regular backups
# - Monitor activity logs regularly

